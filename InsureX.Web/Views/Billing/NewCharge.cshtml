@{ ViewData["Title"] = "Add New Charge"; }
<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Add New Charge</h1>
    @if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }
    @if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
    <div class="card shadow mb-4">
        <div class="card-body">
            <form asp-action="NewCharge" method="post">
                @Html.AntiForgeryToken()
                <div class="form-row">
                    <div class="form-group col-md-4"><label>Charge Type</label><input type="text" name="ChargeType" class="form-control" required /></div>
                    <div class="form-group col-md-4"><label>Amount</label><input type="text" name="Amount" class="form-control" data-type="currency" required /></div>
                    <div class="form-group col-md-4"><label>Description</label><input type="text" name="Description" class="form-control" /></div>
                </div>
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Save Charge</button>
            </form>
        </div>
    </div>
</div>
