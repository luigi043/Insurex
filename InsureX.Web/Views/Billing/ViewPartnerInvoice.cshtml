@{ ViewData["Title"] = "Partner Invoices"; }
<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Partner Invoices</h1>
    <div class="card shadow mb-4">
        <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">Invoice List</h6></div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                    <thead><tr><th>Invoice #</th><th>Partner</th><th>Date</th><th>Amount</th><th>Status</th><th>Actions</th></tr></thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>
