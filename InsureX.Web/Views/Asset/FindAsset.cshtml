@{ ViewData["Title"] = "Find Asset"; }

<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Find Asset</h1>
    @if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }

    <div class="card shadow mb-4">
        <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">Search</h6></div>
        <div class="card-body">
            <form asp-action="FindAsset" method="get">
                <div class="form-row">
                    <div class="form-group col-md-8">
                        <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" class="form-control" placeholder="Search by policy number, ID number, or asset description..." />
                    </div>
                    <div class="form-group col-md-4">
                        <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Search</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (ViewBag.Assets is System.Data.DataTable dt && dt.Rows.Count > 0) {
        <div class="card shadow mb-4">
            <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">Results (@dt.Rows.Count found)</h6></div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                        <thead>
                            <tr><th>Policy #</th><th>Asset Type</th><th>Description</th><th>Finance Value</th><th>Status</th><th>Actions</th></tr>
                        </thead>
                        <tbody>
                            @foreach (System.Data.DataRow row in dt.Rows) {
                                <tr>
                                    <td>@(row.Table.Columns.Contains("vcPolicy_Number") ? row["vcPolicy_Number"] : "")</td>
                                    <td>@(row.Table.Columns.Contains("vcAsset_Type") ? row["vcAsset_Type"] : "")</td>
                                    <td>@(row.Table.Columns.Contains("vcDescription") ? row["vcDescription"] : "")</td>
                                    <td>@(row.Table.Columns.Contains("dcFinance_Value") ? Convert.ToDecimal(row["dcFinance_Value"]).ToString("C", new System.Globalization.CultureInfo("en-ZA")) : "")</td>
                                    <td>@(row.Table.Columns.Contains("vcStatus") ? row["vcStatus"] : "")</td>
                                    <td>
                                        <a href="@Url.Action("UpdateFinanceValue", new { assetId = row.Table.Columns.Contains("iAsset_Id") ? row["iAsset_Id"] : "" })" class="btn btn-sm btn-warning" title="Update Value"><i class="fas fa-edit"></i></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
