@{ ViewData["Title"] = "Update Finance Value"; }

<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Update Finance Value</h1>
    @if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }
    @if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }

    <div class="card shadow mb-4">
        <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">Update Asset Finance Value</h6></div>
        <div class="card-body">
            <form asp-action="UpdateFinanceValue" method="post">
                @Html.AntiForgeryToken()
                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label>Asset ID</label>
                        <input type="number" name="AssetId" value="@Context.Request.Query["assetId"]" class="form-control" required />
                    </div>
                    <div class="form-group col-md-6">
                        <label>New Finance Value (ZAR)</label>
                        <input type="text" name="NewFinanceValue" class="form-control" data-type="currency" required />
                    </div>
                </div>
                <button type="submit" class="btn btn-warning"><i class="fas fa-save"></i> Update Value</button>
            </form>
        </div>
    </div>
</div>
