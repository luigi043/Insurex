@{ ViewData["Title"] = "Uninsured Assets"; }
<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Uninsured Assets</h1>
    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-primary">Asset List</h6>
            <a href="@Url.Action("Export", new { reportType = "UninsuredAssets", format = "csv" })" class="btn btn-sm btn-primary"><i class="fas fa-download"></i> Export</a>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="dataTable"><thead><tr><th>Asset ID</th><th>Type</th><th>Customer</th><th>Finance Value</th><th>Status</th></tr></thead><tbody></tbody></table>
            </div>
        </div>
    </div>
</div>
