@model InsureX.Web.Models.MonthlyReportViewModel
@{ ViewData["Title"] = "Monthly Report"; }
<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Monthly Report</h1>
    <div class="card shadow mb-4">
        <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">Select Date Range</h6></div>
        <div class="card-body">
            <form asp-action="MonthlyReport" method="post">
                @Html.AntiForgeryToken()
                <div class="form-row">
                    <div class="form-group col-md-4"><label>From Date</label><input asp-for="FromDate" type="date" class="form-control" /></div>
                    <div class="form-group col-md-4"><label>To Date</label><input asp-for="ToDate" type="date" class="form-control" /></div>
                    <div class="form-group col-md-4 d-flex align-items-end"><button type="submit" class="btn btn-primary"><i class="fas fa-chart-bar"></i> Generate</button></div>
                </div>
            </form>
        </div>
    </div>
</div>
