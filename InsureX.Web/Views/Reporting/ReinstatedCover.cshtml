@{ ViewData["Title"] = "Reinstated Cover Report"; }

<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Reinstated Cover</h1>
    @if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }

    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex justify-content-between">
            <h6 class="m-0 font-weight-bold text-primary">Report</h6>
            <a href="@Url.Action("Export", new { reportType = "ReinstatedCover" })" class="btn btn-sm btn-success"><i class="fas fa-download"></i> Export CSV</a>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr><th>Policy #</th><th>Customer</th><th>Asset Type</th><th>Description</th><th>Finance Value</th><th>Reinstated Date</th><th>Status</th></tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.Assets is System.Data.DataTable dt) {
                            foreach (System.Data.DataRow row in dt.Rows) {
                                <tr>
                                    <td>@(row.Table.Columns.Contains("vcPolicy_Number") ? row["vcPolicy_Number"] : "")</td>
                                    <td>@(row.Table.Columns.Contains("vcCustomer_Name") ? row["vcCustomer_Name"] : "")</td>
                                    <td>@(row.Table.Columns.Contains("vcAsset_Type") ? row["vcAsset_Type"] : "")</td>
                                    <td>@(row.Table.Columns.Contains("vcDescription") ? row["vcDescription"] : "")</td>
                                    <td>@(row.Table.Columns.Contains("dcFinance_Value") ? Convert.ToDecimal(row["dcFinance_Value"]).ToString("C", new System.Globalization.CultureInfo("en-ZA")) : "")</td>
                                    <td>@(row.Table.Columns.Contains("dtReinstated_Date") ? Convert.ToDateTime(row["dtReinstated_Date"]).ToString("yyyy-MM-dd") : "")</td>
                                    <td>@(row.Table.Columns.Contains("vcStatus") ? row["vcStatus"] : "")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
