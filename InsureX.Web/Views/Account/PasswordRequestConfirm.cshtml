@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Password Reset Sent";
}

<div class="row justify-content-center">
    <div class="col-xl-6 col-lg-8 col-md-9">
        <div class="card border-0 shadow-lg my-5">
            <div class="card-body p-5 text-center">
                <i class="fas fa-envelope fa-3x text-primary mb-3"></i>
                <h4 class="text-gray-900 mb-3">Check Your Email</h4>
                <p>@(TempData["Message"] ?? "If an account with that email exists, a password reset link has been sent.")</p>
                <a class="btn btn-primary" asp-action="Login">Back to Login</a>
            </div>
        </div>
    </div>
</div>
