@model InsureX.Web.Models.PasswordReminderViewModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Password Reminder";
}

<div class="row justify-content-center">
    <div class="col-xl-10 col-lg-12 col-md-9">
        <div class="o-hidden border-0 shadow-lg my-5">
            <div class="p-0">
                <div class="row">
                    <div class="col-lg-6 d-none d-lg-block bg-login-image"></div>
                    <div class="col-lg-6">
                        <div class="p-5">
                            <div class="text-center">
                                <h1 class="h4 text-gray-900 mb-4">Forgot Your Password?</h1>
                                <p class="mb-4">Enter your email address below and we'll send you a link to reset your password.</p>
                            </div>
                            <form asp-action="PasswordReminder" method="post">
                                <div class="form-group">
                                    <input asp-for="Email" class="form-control form-control-user" placeholder="Enter Email Address..." />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>
                                <button type="submit" class="btn btn-primary btn-user btn-block">Reset Password</button>
                            </form>
                            <hr />
                            <div class="text-center">
                                <a class="small" asp-action="Login">Back to Login</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
