@{ ViewData["Title"] = "Confirm Policy Cover"; }

<div class="container-fluid">
    <h1 class="h3 mb-4 text-gray-800">Confirm Policy Cover</h1>
    @if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }
    @if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }

    <div class="card shadow mb-4">
        <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">Pending Confirmations</h6></div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>Policy #</th><th>Customer</th><th>Asset</th><th>Finance Value</th>
                            <th>Insured Value</th><th>Status</th><th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Data populated from ViewBag.PendingPolicies -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
